{
  "manifest_version": 3,
  "name": "Browser Productivity Agent",
  "description": "AI-powered browser assistant for learning and productivity.",
  "version": "1.0.0",

  "action": {
    "default_title": "Browser Productivity Agent",
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ]
    }
  ]
}